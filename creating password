a = input("enter your password: ")

up = lc = dg = sc = 0

if len(a) > 7:
    for ch in a:
        if ch.isupper():
            up += 1
        elif ch.islower():
            lc += 1
        elif ch.isdigit():
            dg += 1
        else:
            sc += 1

    if up > 0 and lc > 0 and dg > 0 and sc > 0:
        print("strong password")
    else:
        print("weak password")
else:
    print("weak due to less characters")
